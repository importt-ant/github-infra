name: Publish to PyPI

# Triggered when a GitHub release is published.
# Requires a PyPI Trusted Publisher configured for this project:
#   https://pypi.org/manage/project/{{ project_name }}/settings/publishing/
#   Publisher: GitHub Actions
#   Owner: {{ github_username }}  Repository: {{ project_name }}
#   Workflow: pypi.yml  Environment: pypi
#
on:
  release:
    types: [published]

jobs:
  pypi:
    uses: {{ github_username }}/github-infra/.github/workflows/python-pypi-publish.yml@main
    with:
      python-version: "{{ min_python }}"
    secrets: inherit
