name: Prepare Release Branch

# Trigger manually from the Actions UI. The workflow will create
# release/<version> from the selected dev branch when it does not exist yet,
# or reuse the existing release branch when it is already present.
on:
  workflow_dispatch:
    inputs:
      dev-branch:
        description: "Source dev branch to branch from when creating the release branch"
        required: true
        default: ""
      version:
        description: "Release version without the leading v; used as release/<version>"
        required: true
        default: ""

permissions:
  contents: write
  pull-requests: write
  models: read

jobs:
  setup:
    name: Parse release inputs
    runs-on: ubuntu-latest
    outputs:
      fingerprints: {% raw %}${{ steps.parse.outputs.fingerprints }}{% endraw %}
      version: {% raw %}${{ steps.parse.outputs.version }}{% endraw %}
      dev_branch: {% raw %}${{ steps.parse.outputs.dev_branch }}{% endraw %}
      release_branch: {% raw %}${{ steps.parse.outputs.release_branch }}{% endraw %}
      groom_branch: {% raw %}${{ steps.parse.outputs.groom_branch }}{% endraw %}

    steps:
      - name: Parse workflow inputs
        id: parse
        run: |
          VERSION_INPUT="{% raw %}${{ github.event.inputs.version || '' }}{% endraw %}"
          DEV_BRANCH="{% raw %}${{ github.event.inputs['dev-branch'] || '' }}{% endraw %}"

          VERSION="${VERSION_INPUT#v}"
          VERSION="${VERSION#release/}"

          if [ -z "$VERSION" ]; then
            echo "Version input is required." >&2
            exit 1
          fi

          if [ -z "$DEV_BRANCH" ]; then
            echo "dev-branch input is required." >&2
            exit 1
          fi

          RELEASE_BRANCH="release/${VERSION}"
          GROOM_BRANCH="groom/release-${VERSION}"

          echo "version=${VERSION}" >> "$GITHUB_OUTPUT"
          echo "dev_branch=${DEV_BRANCH}" >> "$GITHUB_OUTPUT"
          echo "release_branch=${RELEASE_BRANCH}" >> "$GITHUB_OUTPUT"
          echo "groom_branch=${GROOM_BRANCH}" >> "$GITHUB_OUTPUT"
          {
            echo 'fingerprints<<EOF'
            echo 'fingerprints/standardize-docstrings.md'
            echo 'fingerprints/standardize-comments.md'
            echo 'fingerprints/standardize-coding-practices.md'
            echo 'EOF'
          } >> "$GITHUB_OUTPUT"

          echo "Dev branch     : $DEV_BRANCH"
          echo "Release branch : $RELEASE_BRANCH"
          echo "Version        : $VERSION"

  ensure-release-branch:
    name: Ensure release branch exists
    needs: setup
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Create or reuse release branch
        env:
          GH_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          VERSION: {% raw %}${{ needs.setup.outputs.version }}{% endraw %}
          DEV_BRANCH: {% raw %}${{ needs.setup.outputs.dev_branch }}{% endraw %}
          RELEASE_BRANCH: {% raw %}${{ needs.setup.outputs.release_branch }}{% endraw %}
        run: |
          if git ls-remote --exit-code --heads origin "refs/heads/${RELEASE_BRANCH}" >/dev/null 2>&1; then
            echo "Release branch already exists on origin: ${RELEASE_BRANCH}"
            exit 0
          fi

          TAG="v${VERSION}"
          PR_COUNT=$(gh pr list \
            --state all \
            --head "$RELEASE_BRANCH" \
            --json number \
            --jq 'length' 2>/dev/null || echo 0)

          if [ "$PR_COUNT" != "0" ]; then
            echo "Release branch ${RELEASE_BRANCH} appears to have existed before (found ${PR_COUNT} PRs)." >&2
            echo "Refusing to recreate a deleted or merged release branch." >&2
            exit 1
          fi

          if git ls-remote --exit-code --tags origin "refs/tags/${TAG}" >/dev/null 2>&1; then
            echo "Tag ${TAG} already exists; refusing to recreate ${RELEASE_BRANCH}." >&2
            exit 1
          fi

          if gh release view "$TAG" >/dev/null 2>&1; then
            echo "GitHub release ${TAG} already exists; refusing to recreate ${RELEASE_BRANCH}." >&2
            exit 1
          fi

          git fetch origin "$DEV_BRANCH" --no-tags
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git switch -C "$RELEASE_BRANCH" "origin/$DEV_BRANCH"
          git push origin "$RELEASE_BRANCH"

  review:
    name: Groom release branch
    needs: [setup, ensure-release-branch]
    uses: {{ github_username }}/github-infra/.github/workflows/prepare-for-release.yml@main
    with:
      python-version: "{{ min_python }}"
      fingerprints: {% raw %}${{ needs.setup.outputs.fingerprints }}{% endraw %}
      source-branch: {% raw %}${{ needs.setup.outputs.release_branch }}{% endraw %}
      working-branch: {% raw %}${{ needs.setup.outputs.groom_branch }}{% endraw %}
      pr-base-branch: {% raw %}${{ needs.setup.outputs.release_branch }}{% endraw %}
      run-doc-generator: true
    secrets: inherit
