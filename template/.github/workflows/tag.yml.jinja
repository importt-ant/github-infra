name: Tests & GitHub Release

# Triggered when a version tag is pushed (e.g. v1.2.0).
# Runs tests; if they pass, creates a draft GitHub release.
# Publish the draft on GitHub to trigger pypi.yml.
#
on:
  push:
    tags:
      - "v*"

permissions:
  contents: write

jobs:
  tag:
    uses: {{ github_username }}/github-infra/.github/workflows/python-test-release.yml@main
    with:
      python-version: "{{ min_python }}"
      draft: true
    secrets: inherit
